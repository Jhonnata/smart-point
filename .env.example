# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional backend URL for static frontend deployments (GitHub Pages, Netlify, etc).
# Example: https://smart-point-api.onrender.com
VITE_API_BASE_URL=""

# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: Frontend auth/data access for static hosting.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# FRONTEND_ORIGIN: Allowed web origin(s) for CORS and cookie auth in API.
# For multiple origins, separate with comma.
# Example: https://jhonnata.github.io (without trailing slash)
FRONTEND_ORIGIN=""

# CORS_ALLOW_ALL_ORIGINS: Optional fallback to echo any valid Origin header.
# Useful when the frontend URL changes frequently and you auth via Bearer token.
CORS_ALLOW_ALL_ORIGINS="false"

# RESET_PASSWORD_DEBUG: Exposes reset token/url in forgot-password response.
# Keep disabled in production unless you intentionally want the token returned in JSON.
RESET_PASSWORD_DEBUG="false"

# SQLITE_PATH: SQLite file path (use Railway Volume, e.g. /data/ponto.db)
SQLITE_PATH="/data/ponto.db"

# SESSION_COOKIE_SAMESITE: Optional override (Lax, Strict, None). Default is None in production.
SESSION_COOKIE_SAMESITE=""
